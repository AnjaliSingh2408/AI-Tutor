# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional — defaults to models/gemini-2.5-flash. Use models/... or short id (e.g. gemini-2.5-flash).
GEMINI_MODEL=models/gemini-2.5-flash
# Optional — multimodal embeddings model used for text/image/audio index + search.
GEMINI_EMBED_MODEL=models/gemini-embedding-2-preview
